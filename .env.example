# Gemini API Key (get from https://aistudio.google.com/)
GEMINI_API_KEY="your-gemini-api-key"

# App URL
APP_URL="https://your-app.vercel.app"

# Supabase (get from https://supabase.com/dashboard > Project Settings > API)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Bunny.net Storage (https://dash.bunny.net/storage)
# Audio files are uploaded here. The password stays server-side.
BUNNY_STORAGE_ZONE="beci-english"
BUNNY_STORAGE_PASSWORD="your-bunny-storage-password"
BUNNY_STORAGE_REGION="sg"
BUNNY_CDN_HOST="beci-english.b-cdn.net"

# Pexels (optional, for vocabulary images)
VITE_PEXELS_API_KEY=""
